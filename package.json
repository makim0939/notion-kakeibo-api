{
    "name": "notion-kakeibo-api",
    "type": "module",
    "scripts": {
        "dev": "wrangler dev",
        "deploy": "wrangler deploy --minify",
        "cf-typegen": "wrangler types --env-interface CloudflareBindings",
        "prepare": "husky",
        "typecheck": "tsc --noEmit",
        "check": "biome check src/"
    },
    "dependencies": {
        "@notionhq/client": "^5.22.0",
        "hono": "^4.12.23",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@biomejs/biome": "2.4.15",
        "husky": "^9.1.7",
        "lint-staged": "^16.4.0",
        "typescript": "^6.0.3",
        "wrangler": "^4.4.0"
    },
    "lint-staged": {
        "*.{js,jsx,ts,tsx}": [
            "npx @biomejs/biome check --write"
        ]
    }
}
